# BBB Recorder environment configuration
# Copy this file to .env and fill in the required values.

# ── Required ──────────────────────────────────────────────────────────────────

# Full URL of the BigBlueButton room (Greenlight invite link)
BBB_ROOM_URL=https://your-bbb-instance.example.com/rooms/xyz-123/join

# ── Optional – bot behaviour ──────────────────────────────────────────────────

# Display name the bot will use when joining
BOT_NAME=Stream-Bot

# Access code required to enter a protected BBB room (leave empty if not needed)
BBB_ACCESS_CODE=

# How often (in ms) the waiting-room poller checks whether the meeting is open
# Default: 60000 (60 s)
POLL_INTERVAL_MS=60000

# ── Optional – streaming ──────────────────────────────────────────────────────

# RTMP URL for the live stream.
# Leave empty to disable live streaming (recording only).
# Example: rtmp://peertube.example.com/live/your-stream-key
RTMP_URL=

# ── Optional – recording ──────────────────────────────────────────────────────

# Directory inside the container where recordings are stored
RECORDINGS_DIR=/app/recordings

# FFmpeg capture framerate (frames per second, default 25)
CAPTURE_FRAMERATE=25

# FFmpeg capture resolution (WxH, default 1280x720)
CAPTURE_RESOLUTION=1280x720

# ── Optional – PeerTube upload ────────────────────────────────────────────────

# Base URL of your PeerTube instance (no trailing slash)
PEERTUBE_URL=

# PeerTube account credentials
PEERTUBE_USERNAME=
PEERTUBE_PASSWORD=

# Numeric channel id to upload the video to (default: 1)
PEERTUBE_CHANNEL_ID=1

# ── Internal (usually no need to change) ─────────────────────────────────────

# X display used by Xvfb and Puppeteer
DISPLAY=:99

# PulseAudio monitor source name
PULSE_SOURCE=virtual_sink.monitor

# Log level (error | warn | info | debug)
LOG_LEVEL=info
